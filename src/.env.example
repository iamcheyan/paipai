# Google Maps Platform keys
# For this hackathon demo, keys are already hardcoded in app.config.ts (demo only).
# You can create .env to override if needed.
# See notes/GOOGLE_MAPS_SETUP.md for production setup.

EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=your_android_maps_key
EXPO_PUBLIC_GOOGLE_MAPS_IOS_KEY=your_ios_maps_key
EXPO_PUBLIC_GOOGLE_PLACES_KEY=your_places_key

# Fallback
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_ios_maps_key

# For Gemini photo analysis (get from https://aistudio.google.com/app/apikey )
# ⚠️ 重要：创建 key 时必须先切换到 “AI-Architect-Pro” 项目（有 billing 的那个）
# 直接在默认 “Gemini API” 项目下创建的 key（像今天拍拍这个），经常是免费层级 + 没结算信息，
# 导致客户端 vision 分析直接失败（quota / permission / billing required）
# 正确做法：在 AI Studio 顶部项目下拉选 AI-Architect-Pro → 再创建密钥 → 填下面
EXPO_PUBLIC_GEMINI_API_KEY=PLACEHOLDER_PUT_KEY_FROM_AI-Architect-Pro_PROJECT  # 拍拍 Gemini key (必须来自正确项目)